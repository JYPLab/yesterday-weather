KMA_API_KEY=your_api_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/yesterday_weather
PORT=3000
DISCONNECT_BASIC_AUTH=username:password  # 토스 콘솔 연결끊기 콜백 Basic Auth (user:pass 형식)
TOSS_MTLS_CERT=                          # 토스 콘솔 mTLS 인증서 공개키 (.crt 파일 내용 전체)
TOSS_MTLS_KEY=                           # 토스 콘솔 mTLS 인증서 개인키 (.key 파일 내용 전체)
